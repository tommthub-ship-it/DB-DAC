# ─── 간지-DAC 환경설정 ───────────────────────────────────
# 이 파일을 복사해서 .env로 사용하세요
# cp .env.example .env

# ── 로그 레벨 ──────────────────────────────────────────
RUST_LOG=info

# ── API 보안 ───────────────────────────────────────────
API_SECRET=change-me-in-production

# ── Redis 정책 저장소 ──────────────────────────────────
REDIS_PASSWORD=ganji-dac-secret

# ── 개발용 PostgreSQL ──────────────────────────────────
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=devdb

# ── DB 업스트림 주소 ────────────────────────────────────
# 운영 환경에서는 RDS 엔드포인트로 교체
PG_UPSTREAM=postgres:5432
MYSQL_UPSTREAM=mysql:3306
MONGO_UPSTREAM=mongo:27017
REDIS_UPSTREAM=redis:6379

# ── AWS 설정 ────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CloudWatch 감사 로그 (비워두면 파일로만 저장)
CLOUDWATCH_LOG_GROUP=/ganji-dac/audit
CLOUDWATCH_LOG_STREAM=proxy
